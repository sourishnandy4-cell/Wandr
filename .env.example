# Supabase Configuration
# Leave these empty to use localStorage mock mode (no backend required)
# Or fill them in to connect to a real Supabase database

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# To set up Supabase:
# 1. Create a project at https://supabase.com
# 2. Run the SQL files in database/ folder in your Supabase SQL editor
# 3. Copy your project URL and anon key here
# 4. Restart the dev server
